# Copy to .env and adjust as needed. All optional — defaults suit the droplet deploy.

# Base path for built assets. Root ('/') is correct when the droplet serves the
# site at its domain root. (GitHub Pages project sites would use '/<repo>/'.)
VITE_BASE=/

# Absolute URL of the TonConnect manifest the TON wallet fetches. Must be a
# stable, public HTTPS URL. Prefer a named Cloudflare Tunnel or real domain over
# ephemeral *.trycloudflare.com hostnames.
# VITE_TON_MANIFEST_URL=https://your-domain.example/tonconnect-manifest.json

# Bridge status endpoint polled by the Bridge status panel. Same-origin '/api/status'
# works when nginx proxies /api to the droplet's status service.
VITE_BRIDGE_STATUS_URL=/api/status
